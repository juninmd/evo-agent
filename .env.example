# LiteLLM Proxy / Gateway API configurations
# Default: OpenRouter direct with cheap Chinese model (z-ai/glm-4-32b).
# To route via the cluster LiteLLM proxy instead, set:
#   LITELLM_API_BASE=http://litellm.ai.svc.cluster.local:4000/v1  and a proxy model name.
LITELLM_API_BASE=https://openrouter.ai/api/v1
LITELLM_API_KEY=sk-or-v1-...
LITELLM_MODEL=z-ai/glm-4-32b
# Optional: request timeout in ms (default 300000)
LITELLM_TIMEOUT_MS=300000


# Telegram
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=123456789

# GitHub Pages (articles repo)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-username
GITHUB_REPO=evo-agent-articles
GITHUB_BRANCH=gh-pages

# Agent tuning (optional)
CRAWL_INTERVAL_MINUTES=40
ARTICLE_CRON=0 8 * * *
LOG_LEVEL=info

# Isolated smoke tests (optional)
# DB_PATH=data/knowledge.db
