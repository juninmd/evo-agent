# OpenCode Zen — API key grátis em opencode.ai/zen (sem cartão de crédito)
# Modelos gratuitos disponíveis:
#   opencode/deepseek-v4-flash-free
#   opencode/minimax-m2.5-free
#   opencode/nemotron-3-super-free
#   opencode/big-pickle
OPENCODE_ZEN_API_KEY=oc-zen-...
OPENCODE_PROVIDER=opencode
OPENCODE_MODEL=opencode/deepseek-v4-flash-free

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=123456789

# GitHub Pages (articles repo)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-username
GITHUB_REPO=evo-agent-articles
GITHUB_BRANCH=gh-pages

# Agent tuning (optional)
CRAWL_INTERVAL_MINUTES=40
ARTICLE_CRON=0 8 * * *
LOG_LEVEL=info

# Isolated smoke tests (optional)
# DB_PATH=data/knowledge.db
