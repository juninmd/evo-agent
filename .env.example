# LiteLLM Proxy / Gateway — todas as requisições passam pelo gateway central.
# O provider real (OpenRouter z-ai/glm-4-32b) é configurado DENTRO do LiteLLM,
# não aqui. Aqui usa-se a virtual key do LiteLLM, não a key do OpenRouter.
LITELLM_API_BASE=http://litellm.ai.svc.cluster.local:4000/v1
LITELLM_API_KEY=sk-...           # LiteLLM virtual key
LITELLM_MODEL=z-ai/glm-4-32b
LITELLM_FALLBACK_MODELS=cloud/maverick,cloud/llama-8b
# Optional: request timeout in ms (default 300000)
LITELLM_TIMEOUT_MS=300000
LITELLM_MAX_OUTPUT_TOKENS=12000


# Telegram
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=123456789

# GitHub Pages (articles repo)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-username
GITHUB_REPO=evo-agent-articles
GITHUB_BRANCH=gh-pages

# Agent tuning (optional)
CRAWL_INTERVAL_MINUTES=40
ARTICLE_CRON=0 8 * * *
LOG_LEVEL=info
LOG_FORMAT=json
RUN_MODE=DAEMON

# Isolated smoke tests (optional)
DB_PATH=data/knowledge.db
SEARXNG_URL=http://searxng.searxng.svc.cluster.local
