{
  "name": "evo-agent",
  "version": "1.0.0",
  "description": "Self-improving AI developer agent",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "health": "tsx src/observability/health-cli.ts",
    "benchmark:editorial": "tsx src/agent/benchmark-cli.ts",
    "prompt:rollback": "tsx src/agent/prompt-rollback-cli.ts",
    "backfill:articles": "node dist/agent/backfill-cli.js",
    "smoke:reddit-comments": "tsx src/crawler/reddit-smoke.ts",
    "build": "tsc",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@octokit/rest": "^21.0.0",
    "ai": "^6.0.193",
    "axios": "^1.7.0",
    "better-sqlite3": "^11.0.0",
    "node-cron": "^4.2.1",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
